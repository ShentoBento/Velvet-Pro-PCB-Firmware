    // split_keyboard: enables the split keyboard subsystem (serial transport etc).
    // ── DYNAMIC KEYMAP ────────────────────────────────────────────
    // layer_count: how many layers Via/Vial exposes. Each layer uses
    // rows × cols × 2 bytes of EEPROM. Default is 4.
    "dynamic_keymap": {
        "layer_count": 4
    },

